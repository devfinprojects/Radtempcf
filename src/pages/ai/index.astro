---
// AI Integration Hub Page
import BaseLayout from '../../layouts/BaseLayout.astro';

const promptTemplates = [
  { 
    name: 'ChatGPT Findings Generator', 
    description: 'Generate radiology findings from structured data using ChatGPT',
    link: '/ai/prompts/chatgpt-findings',
    format: 'prompt'
  },
  { 
    name: 'Claude Impression Writer', 
    description: 'AI-assisted impression section generation using Claude',
    link: '/ai/prompts/claude-impression',
    format: 'prompt'
  },
  { 
    name: 'Gemini Structured Report', 
    description: 'Generate structured reports using Gemini',
    link: '/ai/prompts/gemini-report',
    format: 'prompt'
  },
];

const nlpSchemas = [
  { 
    name: 'Findings Extraction', 
    description: 'Extract findings from free-text reports using NLP',
    link: '/ai/schemas/findings',
    format: 'json'
  },
  { 
    name: 'Impression Parser', 
    description: 'Parse impression sections into structured data',
    link: '/ai/schemas/impression',
    format: 'json'
  },
  { 
    name: 'Recommendations Extractor', 
    description: 'Extract follow-up recommendations from reports',
    link: '/ai/schemas/recommendations',
    format: 'json'
  },
];

const models = [
  { name: 'GPT-4', provider: 'OpenAI', bestFor: 'General reporting' },
  { name: 'Claude 3', provider: 'Anthropic', bestFor: 'Complex reasoning' },
  { name: 'Gemini Pro', provider: 'Google', bestFor: 'Multimodal reports' },
];
---

<BaseLayout title="AI Integration">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-4">AI Integration Hub</h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-12">
      LLM prompt templates and NLP schemas for AI-assisted radiology reporting.
    </p>
    
    <!-- LLM Prompts Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">LLM Prompt Templates</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-6">
        Pre-built prompts for generating radiology findings and impressions using large language models.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {promptTemplates.map(prompt => (
          <a href={prompt.link} class="block bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-lg transition p-6">
            <span class="inline-block px-2 py-1 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs rounded mb-3">
              {prompt.format.toUpperCase()}
            </span>
            <h3 class="text-lg font-semibold mb-2">{prompt.name}</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">{prompt.description}</p>
          </a>
        ))}
      </div>
    </section>
    
    <!-- NLP Schemas Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">NLP Extraction Schemas</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-6">
        JSON schemas for extracting structured data from free-text reports.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {nlpSchemas.map(schema => (
          <a href={schema.link} class="block bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-lg transition p-6">
            <span class="inline-block px-2 py-1 bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 text-xs rounded mb-3">
              JSON SCHEMA
            </span>
            <h3 class="text-lg font-semibold mb-2">{schema.name}</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">{schema.description}</p>
          </a>
        ))}
      </div>
    </section>
    
    <!-- Supported Models -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Supported Models</h2>
      <div class="overflow-x-auto">
        <table class="w-full bg-white dark:bg-gray-800 rounded-lg shadow">
          <thead>
            <tr class="border-b dark:border-gray-700">
              <th class="px-6 py-3 text-left">Model</th>
              <th class="px-6 py-3 text-left">Provider</th>
              <th class="px-6 py-3 text-left">Best For</th>
            </tr>
          </thead>
          <tbody>
            {models.map(model => (
              <tr class="border-b dark:border-gray-700">
                <td class="px-6 py-4">{model.name}</td>
                <td class="px-6 py-4 text-gray-600 dark:text-gray-400">{model.provider}</td>
                <td class="px-6 py-4 text-gray-600 dark:text-gray-400">{model.bestFor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
    
    <!-- Documentation Link -->
    <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6">
      <h2 class="text-xl font-semibold mb-4">Documentation</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Learn how to integrate AI features into your radiology workflow.
      </p>
      <a href="/docs/ai" class="text-blue-600 hover:underline">View AI Integration Guide →</a>
    </div>
  </div>
</BaseLayout>