        "status": "green",
        "trend": "stable",
        "lastUpdated": ""
      },
      {
        "id": "kpi-004",
        "name": "Addendum Rate",
        "currentValue": 0,
        "targetValue": 5,
        "unit": "percentage",
        "status": "green",
        "trend": "improving",
        "lastUpdated": ""
      },
      {
