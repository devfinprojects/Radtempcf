      "enabled": true,
      "recipients": ["radiology-lead@radiology.example.com"],
      "metrics": ["turnaroundTime", "criticalResultsCommunication"]
    },
    "weeklyReport": {
      "enabled": true,
      "recipients": ["department-chief@radiology.example.com"],
      "metrics": ["addendumRate", "templateUtilization", "discrepancyRate"]
