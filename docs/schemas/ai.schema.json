{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/devfinprojects/Radtempcf/main/docs/schemas/ai.schema.json",
  "title": "AI Integration",
  "description": "Schema for AI integration data in radiology templates",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether AI integration is enabled"
    },
    "model": {
      "type": "string",
      "description": "AI model name or version"
    },
    "provider": {
      "type": "string",
      "description": "AI service provider"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "auto-detection",
          "quantification",
          "classification",
          "comparison",
          "suggestion"
        ]
      },
      "description": "AI features used"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "AI confidence score"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "probability": {
            "type": "number"
          }
        }
      },
      "description": "AI-detected findings"
    },
    "processingTime": {
      "type": "number",
      "description": "Processing time in milliseconds"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Processing timestamp"
    }
  }
}
