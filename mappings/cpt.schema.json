{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/devfinprojects/Radtempcf/main/mappings/cpt.schema.json",
  "title": "CPT Code Mapping",
  "description": "Mapping of radiology template procedures to CPT codes",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "templateId": {
      "type": "string",
      "description": "Reference to template ID"
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["procedure", "cptCode", "cptDescription"],
        "properties": {
          "procedure": {
            "type": "string",
            "description": "Procedure type"
          },
          "cptCode": {
            "type": "string",
            "pattern": "^\\d{5}$",
            "description": "CPT code (5 digits)"
          },
          "cptDescription": {
            "type": "string",
            "description": "CPT code description"
          },
          "category": {
            "type": "string",
            "enum": ["radiology", "interventional", "contrast", "additional"]
          }
        }
      }
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  }
}
